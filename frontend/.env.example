# PocketBase backend URL (auth + data collections). Built by the backend slice.
VITE_PB_URL=http://127.0.0.1:8090

# Path of the backend custom send route (POST). Frontend posts the Resend key +
# selected template + recipients here; the backend performs the Resend call and
# writes `logs` rows. Override only if the backend uses a different path.
VITE_SEND_ROUTE=/api/kreach/send
