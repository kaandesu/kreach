# Copy to `.env` and adjust as needed: `cp .env.example .env`

# ---- Compose profile -------------------------------------------------------
# Selects which profile starts. Use `dev` locally (enables the override file's
# hot-reload), `prod` for deployment-shaped runs.
COMPOSE_PROFILES=dev

# ---- Host port mappings ----------------------------------------------------
FRONTEND_PORT=3000
BACKEND_PORT=8080
POCKETBASE_PORT=8090

# ---- Frontend (Next.js, NEXT_PUBLIC_* is exposed to the browser) -----------
# These are the URLs the browser uses, so they point at the host, not the
# internal compose service names.
NEXT_PUBLIC_API_URL=http://localhost:8080
NEXT_PUBLIC_POCKETBASE_URL=http://localhost:8090

# ---- Backend ---------------------------------------------------------------
# POCKETBASE_URL for the backend is set in docker-compose.yml to the internal
# service name (http://pocketbase:8090) and normally needs no override here.

# ---- PocketBase build args -------------------------------------------------
PB_VERSION=0.22.21
# CPU architecture for the PocketBase binary:
#   amd64  -> Intel/AMD hosts and most cloud/Coolify servers
#   arm64  -> Apple Silicon (M-series) when building/running natively
PB_ARCH=amd64

# PocketBase admin: create the first superuser on initial startup via the UI at
# http://localhost:8090/_/  (or run `pocketbase superuser create <email> <pw>`).
