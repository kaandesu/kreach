# Copy to `.env` and adjust as needed: `cp .env.example .env`

# ---- Compose profile -------------------------------------------------------
# Selects which profile starts. Use `dev` locally (enables the override file's
# hot-reload), `prod` for deployment-shaped runs.
COMPOSE_PROFILES=dev

# ---- Host port mappings ----------------------------------------------------
FRONTEND_PORT=3000
BACKEND_PORT=8080

# ---- Frontend (Vite, VITE_* is exposed to the browser at build time) -------
# These are the URLs the browser uses, so they point at the host, not the
# internal compose service names.
VITE_PB_URL=http://localhost:8080
VITE_SEND_ROUTE=/api/emails/send

# ---- Backend ---------------------------------------------------------------
RESEND_FROM=onboarding@resend.dev

# ---- PocketBase build args -------------------------------------------------
# PocketBase is embedded in the backend service. Create the first superuser via
# the backend dashboard at http://localhost:8080/_/ after initial startup.
